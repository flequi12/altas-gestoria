# Copia este fichero a .env y rellena los valores. .env NUNCA se sube al repo.

# Puerto del servidor web
PORT=3010

# --- IA (extraccion) ---
# Clave de la API de Claude (Anthropic). Sin ella, /api/extraer responde 503.
ANTHROPIC_API_KEY=
# Modelo de extraccion. Por defecto el mas capaz; el volumen es bajo (~20-50/mes)
# asi que el coste es despreciable y prima la exactitud (datos legales, fotos de DNI).
EXTRACTION_MODEL=claude-opus-4-8
ANTHROPIC_VERSION=2023-06-01

# --- Login propio (sustituye al Basic Auth) ---
# Si no se define ni APP_PASS_HASH ni APP_PASS, la auth queda DESACTIVADA (modo dev local).
APP_USER=gestoria
# PREFERIDO: hash scrypt, asi la contrasena no viaja en claro en el .env.
# Generar con:  node -e "const c=require('crypto');const s=c.randomBytes(16);console.log('scrypt$'+s.toString('hex')+'$'+c.scryptSync(process.argv[1],s,32).toString('hex'))" 'TU_CONTRASENA'
APP_PASS_HASH=
# Alternativa simple (contrasena en claro). Usa solo una de las dos; si hay HASH, manda el HASH.
# APP_PASS=
# Secreto HMAC de la cookie de sesion. Fijar uno aleatorio y estable (si cambia, caduca las sesiones).
SESSION_SECRET=
# Duracion de la sesion en dias (def. 7).
SESSION_DIAS=7
